// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String         @id @default(uuid())
  username     String         @unique
  passwordHash String
  role         String         @default("owner") // "super_admin" | "owner"
  createdAt    DateTime       @default(now())
  guests       Guest[]
  weddingConfig WeddingConfig?
}

model Guest {
  id             String        @id @default(uuid())
  name           String
  slug           String        @unique
  phone          String?
  group          String?       // e.g. "Keluarga", "Teman", "Kantor"
  rsvpStatus     String        @default("pending") // pending | confirmed | declined
  numberOfGuests Int           @default(1)
  wishes         String?
  wishSentAt     DateTime?
  openedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  userId         String?
  owner          User?         @relation(fields: [userId], references: [id])
  @@index([userId])
}

model WeddingConfig {
  id             String    @id @default(uuid())
  groomName      String    @default("")
  groomNickname  String    @default("")
  groomParents   String    @default("")
  brideName      String    @default("")
  brideNickname  String    @default("")
  brideParents   String    @default("")
  akadDate       String    @default("")
  akadTime       String    @default("")
  akadVenue      String    @default("")
  akadAddress    String    @default("")
  akadMapsUrl    String    @default("")
  resepsiDate    String    @default("")
  resepsiTime    String    @default("")
  resepsiVenue   String    @default("")
  resepsiAddress String    @default("")
  resepsiMapsUrl String    @default("")
  loveStory      String    @default("[]") // JSON array
  giftInfo       String    @default("[]") // JSON array
  heroImage      String?
  groomImage     String?
  brideImage     String?
  coupleImage    String?
  galleryImages  String    @default("[]") // JSON array
  musicUrl       String?
  theme          String    @default("sage")
  showLoveStory  Boolean   @default(true)
  showGiftInfo   Boolean   @default(true)
  showRsvp       Boolean   @default(true)
  showGallery    Boolean   @default(true)
  showAkad       Boolean   @default(true)
  showResepsi    Boolean   @default(true)
  akadTitle      String    @default("Akad Nikah")
  resepsiTitle   String    @default("Resepsi Pernikahan")
  whatsappTemplate String?
  groomImagePosition String?   @default("center")
  brideImagePosition String?   @default("center")
  heroImagePosition  String?   @default("center")
  userId         String?   @unique
  owner          User?     @relation(fields: [userId], references: [id])
}
