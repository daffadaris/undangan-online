// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}


model Guest {
  id             String    @id @default(uuid())
  name           String
  slug           String    @unique
  phone          String?
  group          String?   // e.g. "Keluarga", "Teman", "Kantor"
  rsvpStatus     String    @default("pending") // pending | confirmed | declined
  numberOfGuests Int       @default(1)
  wishes         String?
  wishSentAt     DateTime?
  openedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WeddingConfig {
  id             String    @id @default("config")
  groomName      String    @default("Daffa' Daris Mahendra Ansori")
  groomNickname  String    @default("Daffa")
  groomParents   String    @default("Putra dari Bpk. Ansori & Ibu Ansori")
  brideName      String    @default("Regina Pingkan Sayyidhina Arif")
  brideNickname  String    @default("Regina")
  brideParents   String    @default("Putri dari Bpk. Arif & Ibu Arif")
  akadDate       String    @default("2026-08-08")
  akadTime       String    @default("08:00 - 10:00 WIB")
  akadVenue      String    @default("Masjid Agung")
  akadAddress    String    @default("Jl. Raya No. 1")
  akadMapsUrl    String    @default("https://maps.google.com")
  resepsiDate    String    @default("2026-08-08")
  resepsiTime    String    @default("11:00 - 14:00 WIB")
  resepsiVenue   String    @default("Gedung Serbaguna")
  resepsiAddress String    @default("Jl. Raya No. 2")
  resepsiMapsUrl String    @default("https://maps.google.com")
  loveStory      String    @default("[]") // JSON array
  giftInfo       String    @default("[]") // JSON array
  heroImage      String?
  groomImage     String?
  brideImage     String?
  coupleImage    String?
  galleryImages  String    @default("[]") // JSON array
  musicUrl       String?
  theme          String    @default("sage")
  showLoveStory  Boolean   @default(true)
  showGiftInfo   Boolean   @default(true)
  showRsvp       Boolean   @default(true)
  showGallery    Boolean   @default(true)
  showAkad       Boolean   @default(true)
  showResepsi    Boolean   @default(true)
}
